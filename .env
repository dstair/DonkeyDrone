# gz-python (Gazebo Harmonic Python bindings) — installed by Homebrew for Python 3.12
# These are required for gz-transport camera frames in native macOS mode.
PYTHONPATH=/opt/homebrew/lib/python3.12/site-packages
# Use FALLBACK so pygame's bundled libSDL2 (in .venv/.../pygame/.dylibs)
# is preferred via @loader_path. The Homebrew libSDL2 doesn't enumerate
# joysticks via IOHID on macOS — using it breaks Xbox controller input.
# gz-python libs resolve via @rpath, which is unaffected by FALLBACK.
DYLD_FALLBACK_LIBRARY_PATH=/opt/homebrew/lib
GZ_IP=127.0.0.1
